/**
 * Capacitor config for Ride Driver App (separate APK)
 * App ID: com.hndriver.ride
 * OTA: loads from production server — updates appear automatically
 */
{
  "appId": "com.hndriver.ride",
  "appName": "HN Driver - سائق",
  "webDir": "dist-driver-ride",
  "server": {
    "url": "https://ride.hn-driver.com",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0A0A0A",
      "showSpinner": true,
      "spinnerColor": "#F97316"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0A0A0A"
    }
  }
}
